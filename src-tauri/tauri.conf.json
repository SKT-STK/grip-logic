{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "grip-logic",
  "version": "0.1.0",
  "identifier": "com.skt-stk.grip-logic",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "grip-logic",
        "width": 800,
        "height": 600,
        "maximizable": false,
        "minimizable": true,
        "resizable": false,
        "label": "main",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "_dev/InputSimulator.dll": "./InputSimulator.dll"
    }
  }
}
